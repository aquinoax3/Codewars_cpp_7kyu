#include <string>
#include <iostream>

bool valid_spacing(const std::string& s) {
  if (s[0] == ' ' || s[s.size() - 1] == ' ') {
    return false;
  }
  
  
  for (int i = 0; i < s.size(); i++) {
    if (isalpha(s[i - 1]) && s[i] == ' ' && isalpha(s[i + 1])) {
      return false;
    }
  }
  
    
  return true; 
}
